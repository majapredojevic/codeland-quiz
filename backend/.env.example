APP_NAME=CodeLand Quiz
APP_ENV=development
APP_URL=https://localhost

DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

ACCESS_TOKEN_COOKIE_NAME=__Host-codeland_access
REFRESH_TOKEN_COOKIE_NAME=__Host-codeland_refresh
COOKIE_PATH=/
CSRF_TOKEN_COOKIE_NAME=__Host-codeland_csrf

JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
REFRESH_TOKEN_EXPIRATION_DAYS=7
CSRF_TOKEN_EXPIRATION_MINUTES=120

LOGIN_ATTEMPT_LIMIT=5
LOGIN_LOCK_DURATION_MINUTES=15

COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=Strict

MAX_UPLOAD_SIZE_MB=5
DEFAULT_QUIZ_QUESTION_TIME_LIMIT_SECONDS=30
MAXIMUM_NICKNAME_LENGTH=100
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp

DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=20